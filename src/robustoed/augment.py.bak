from __future__ import annotations

from dataclasses import dataclass
from typing import Dict, List, Optional, Sequence, Tuple, Union

import numpy as np
import sympy as sp
from scipy.optimize import dual_annealing

from .types import Design
from .grid import make_grid_equidistant
from .fisher import information_matrix
from .optim import WynnFedorovOptions, wynn_fedorov_d_opt
from .regularize import AutoRegularization, regularize_if_needed
from .criterion_d import logdet_psd
from .criterion_d import d_efficiency_relative_shared_ridge

Array = np.ndarray

def _aug_min_dist_to_support(x: Array, support: Array) -> float:
    """Min Euclidean distance from x to any row in support."""
    x = np.asarray(x, dtype=float).reshape(1, -1)
    support = np.asarray(support, dtype=float)
    if support.size == 0:
        return float("inf")
    dists = np.linalg.norm(support - x, axis=1)
    return float(np.min(dists))


def _aug_canonicalize_set(X: Array) -> Array:
    """Sort rows lexicographically so that {x1,x2} == {x2,x1}."""
    X = np.asarray(X, dtype=float)
    idx = np.lexsort(X.T[::-1])
    return X[idx]


Bounds = List[Tuple[float, float]]
PointSet = Array  # shape (n_per_step, d)


@dataclass
class RobustAugmentResult:
    design_base: Design
    design_augm: Design
    x1_star: PointSet  # shape (n_per_step, d)
    x2_star: PointSet  # shape (n_per_step, d)
    delta: List[PointSet]
    meta: Dict[str, object]


def _theta_dict_to_vector(theta_symbols: Sequence[sp.Symbol], theta_dict: Dict[sp.Symbol, float]) -> Array:
    return np.array([float(theta_dict[s]) for s in theta_symbols], dtype=float)


def _merge_exact(points: Array, weights: Array) -> Design:
    """Merge exact duplicate points (row-equality)."""
    pts = np.asarray(points, dtype=float)
    w = np.asarray(weights, dtype=float)
    acc: Dict[Tuple[float, ...], float] = {}
    order: List[Tuple[float, ...]] = []
    for row, wi in zip(pts, w):
        k = tuple(row.tolist())
        if k not in acc:
            acc[k] = float(wi)
            order.append(k)
        else:
            acc[k] += float(wi)
    out_pts = np.array(order, dtype=float)
    out_w = np.array([acc[k] for k in order], dtype=float)
    out_w = out_w / out_w.sum()
    return Design(out_pts, out_w)


def _equal_weight_design(design: Design) -> Design:
    """Return same support with equal weights."""
    pts = np.asarray(design.points, dtype=float)
    m = pts.shape[0]
    w = np.ones(m, dtype=float) / m
    return Design(pts, w)


def _design_supported_on_set(X: PointSet) -> Design:
    """Design supported on rows of X with equal weights."""
    X = np.asarray(X, dtype=float)
    if X.ndim != 2:
        raise ValueError("X must have shape (n, d).")
    n = X.shape[0]
    w = np.ones(n, dtype=float) / n
    return Design(X, w)


def _augment_design(
    base: Design,
    X_sets: List[PointSet],
    *,
    alpha_mode: str,
    alpha: float,
) -> Design:
    """
    Build augmented design according to paper strategies.

    - alpha_mode="fixed": keep base weights scaled by (1-alpha) and allocate alpha
      equally among all newly added points (across both steps if provided).
    - alpha_mode="equal_weight": final design equally weighted among all support points
      (base support + all added points). This corresponds to varying alpha with #points. 
    """
    if alpha_mode not in ("fixed", "equal_weight"):
        raise ValueError("alpha_mode must be 'fixed' or 'equal_weight'.")

    base_pts = np.asarray(base.points, dtype=float)
    base_w = np.asarray(base.weights, dtype=float)

    added_pts = []
    for X in X_sets:
        X = np.asarray(X, dtype=float)
        if X.size == 0:
            continue
        if X.ndim != 2:
            raise ValueError("Each X must have shape (n, d).")
        added_pts.append(X)
    if len(added_pts) == 0:
        return base

    all_added = np.vstack(added_pts)

    if alpha_mode == "equal_weight":
        pts = np.vstack([base_pts, all_added])
        # merge duplicates, then equal weights
        merged = _merge_exact(pts, np.ones(pts.shape[0], dtype=float))
        m = merged.points.shape[0]
        w = np.ones(m, dtype=float) / m
        return Design(merged.points, w)

    # fixed alpha
    if not (0.0 < alpha < 1.0):
        raise ValueError("alpha must be in (0, 1) when alpha_mode='fixed'.")

    n_added = all_added.shape[0]
    w0 = (1.0 - alpha) * base_w
    w_added = np.ones(n_added, dtype=float) * (alpha / n_added)
    pts = np.vstack([base_pts, all_added])
    w = np.concatenate([w0, w_added])
    return _merge_exact(pts, w)


def _d_efficiency_formal(
    model,
    design_test: Design,
    design_opt: Design,
    theta_vec: Array,
    *,
    reg: AutoRegularization,
) -> float:
    """
    Formal efficiency consistent with our sensitivity module:
    shared ridge based on trace(M_opt), clip to <= 1.
    """
    M_test = information_matrix(model, design_test, theta_vec)
    M_opt = information_matrix(model, design_opt, theta_vec)
    p = theta_vec.shape[0]

    tr = float(np.trace(M_opt))
    if (not np.isfinite(tr)) or tr <= 0:
        tr = float(np.trace(M_test))
    if (not np.isfinite(tr)) or tr <= 0:
        tr = 1.0

    ridge = float(reg.eps0) * tr / p
    eff_raw = d_efficiency_relative_shared_ridge(M_test, M_opt, p, ridge=ridge)
    return float(min(1.0, eff_raw))


def _argmax_one_point_variance(
    model,
    base_design: Design,
    theta_vec: Array,
    bounds: Bounds,
    *,
    reg: AutoRegularization,
    seed: Optional[int],
    maxiter: int,
    exclude_support: Optional[Array] = None,
    exclude_tol: float = 0.0,
) -> Array:
    """
    For D-opt, Algorithm 1 step 2 can be simplified to maximize d(x, xi0*) = f^T M^{-1} f. 
    """
    d = len(bounds)
    M = information_matrix(model, base_design, theta_vec)
    M, _ = regularize_if_needed(M, reg=reg)

    def obj(x_flat: Array) -> float:
        x = np.asarray(x_flat, dtype=float).reshape(d)
        if exclude_support is not None and exclude_tol > 0.0:
            if _aug_min_dist_to_support(x, exclude_support) < float(exclude_tol):
                return 1e6
        f = model.jacobian(x, theta_vec).reshape(-1, 1)
        v = float((f.T @ np.linalg.solve(M, f))[0, 0])
        return -v

    res = dual_annealing(obj, bounds=bounds, seed=seed, maxiter=maxiter)
    return np.asarray(res.x, dtype=float).reshape(d)


def _logdet_augmented_for_set(
    model,
    base_design_for_weights: Design,
    theta_vec: Array,
    X: PointSet,
    *,
    alpha_mode: str,
    alpha: float,
    reg: AutoRegularization,
) -> float:
    """
    Objective for step 2 when the candidate is a set X of n points:
    maximize logdet(M( xi1(X) )) (equivalent to maximizing D-eff since denominator is constant per scenario).
    For n=1, we already have a simplification; for n=2 we use this direct objective. 
    """
    xi1 = _augment_design(base_design_for_weights, [X], alpha_mode=alpha_mode, alpha=alpha)
    M = information_matrix(model, xi1, theta_vec)
    M, _ = regularize_if_needed(M, reg=reg)
    return logdet_psd(M)


def _argmax_two_point_set(
    model,
    base_design_for_weights: Design,
    theta_vec: Array,
    bounds: Bounds,
    *,
    alpha_mode: str,
    alpha: float,
    reg: AutoRegularization,
    seed: Optional[int],
    maxiter: int,
    exclude_support: Optional[Array] = None,
    exclude_tol: float = 0.0,
) -> PointSet:
    """
    Find X_beta = argmax_X D-eff_beta( xi1(X) ) where X has 2 points.
    We maximize logdet(M(xi1(X))) directly (paper-consistent, denominator constant). 
    """
    d = len(bounds)

    def obj(u: Array) -> float:
        u = np.asarray(u, dtype=float).reshape(2 * d)
        x1 = u[:d]
        x2 = u[d:]
        X = np.vstack([x1, x2])
        if exclude_support is not None and exclude_tol > 0.0:
            if _aug_min_dist_to_support(x1, exclude_support) < float(exclude_tol):
                return 1e6
            if _aug_min_dist_to_support(x2, exclude_support) < float(exclude_tol):
                return 1e6

        # penalty if points identical (optional)
        if float(np.linalg.norm(x1 - x2)) < 1e-8:
            return 1e6
        return -_logdet_augmented_for_set(
            model, base_design_for_weights, theta_vec, X,
            alpha_mode=alpha_mode, alpha=alpha, reg=reg
        )

    res = dual_annealing(obj, bounds=bounds * 2, seed=seed, maxiter=maxiter)
    u = np.asarray(res.x, dtype=float).reshape(2 * d)
    x1 = u[:d]
    x2 = u[d:]
    return np.vstack([x1, x2])


def robust_augment_two_step(
    model,
    *,
    theta_symbols: Sequence[sp.Symbol],
    theta0: Dict[sp.Symbol, float],
    bounds: Bounds,
    uncertain_params: Sequence[sp.Symbol],
    grid_spec: Optional[Dict[sp.Symbol, Tuple[float, float, int]]] = None,
    rel_range: float = 0.15,
    grid_points: int = 21,
    # how many points in each step
    n_per_step: int = 1,  # supported: 1 or 2
    # weights strategy
    alpha_mode: str = "fixed",    # "fixed" or "equal_weight"
    alpha: float = 0.25,          # used if alpha_mode="fixed"
    # options
    wynn_base: Optional[WynnFedorovOptions] = None,
    wynn_ref: Optional[WynnFedorovOptions] = None,
    reg: AutoRegularization = AutoRegularization(),
    rounding_digits: int = 3,
    exclude_tol: Optional[float] = None,
    # optimization for candidate computation
    da_maxiter: int = 250,
    seed: Optional[int] = 1,
) -> RobustAugmentResult:
    """
    Paper Algorithm 1 generalized to sets X of size n_per_step (n_per_step=1 or 2).

    - Build grid Ω over uncertain_params. Grid discretization is chosen by researcher. :contentReference[oaicite:9]{index=9}
    - Compute xi0* at theta0.
    - Step 2: for each scenario beta_z compute candidate set X_beta_z (|X|=n_per_step) by maximizing D-eff_beta_z(xi1(X)).
      For D-opt and n=1 we use the simplification argmax f^T M^{-1} f. 
      For n=2 we maximize logdet(M(xi1(X))) directly.
    - Step 3: choose X1* in Δ maximizing the maximum improvement over the grid.
    - Step 5: choose X2* in Δ maximizing the minimum efficiency over the grid.
    - Return augmented design with two sets added (total 2*n_per_step points). 
    """
    if n_per_step not in (1, 2):
        raise ValueError("Currently only n_per_step=1 or n_per_step=2 is supported.")

    if alpha_mode not in ("fixed", "equal_weight"):
        raise ValueError("alpha_mode must be 'fixed' or 'equal_weight'.")

    if wynn_base is None:
        wynn_base = WynnFedorovOptions(max_iter=60, tol=1e-5, rounding_digits=2, merge_tol=0.01, seed=seed, da_maxiter=150)
    if wynn_ref is None:
        wynn_ref = WynnFedorovOptions(max_iter=120, tol=1e-7, rounding_digits=3, merge_tol=0.001, seed=seed, da_maxiter=300)

    # Build Ω
    if grid_spec is None:
        spec: Dict[sp.Symbol, Tuple[float, float, int]] = {}
        for s in uncertain_params:
            if s not in theta0:
                raise ValueError(f"theta0 missing value for parameter {s}.")
            v = float(theta0[s])
            spec[s] = (v * (1.0 - rel_range), v * (1.0 + rel_range), int(grid_points))
        grid = make_grid_equidistant(spec)
    else:
        grid = make_grid_equidistant(grid_spec)

    theta0_vec = _theta_dict_to_vector(theta_symbols, theta0)

    # base design xi0*
    res0 = wynn_fedorov_d_opt(model=model, theta=theta0_vec, bounds=bounds, n_support=6, options=wynn_base)
    xi0 = res0.design
    d = xi0.points.shape[1]

    # For equal_weight mode, Algorithm 1 "equally weighted designs" implies weights equal on support points,
    # hence alpha changes with #points and the D-opt part loses weight as points are added. 
    xi0_for_weights = _equal_weight_design(xi0) if alpha_mode == "equal_weight" else xi0

    if exclude_tol is None:
        exclude_tol = 10 ** (-int(rounding_digits))


    # scenario optima for formal efficiency evaluations
    theta_vecs: List[Array] = []
    xi_opt: List[Design] = []
    for scen in grid:
        theta_s = dict(theta0)
        theta_s.update(scen)
        th = _theta_dict_to_vector(theta_symbols, theta_s)
        theta_vecs.append(th)
        res_opt = wynn_fedorov_d_opt(model=model, theta=th, bounds=bounds, n_support=6, options=wynn_ref)
        xi_opt.append(res_opt.design)

    # Step 2: compute Δ = {X_beta_z}
    delta: List[PointSet] = []
    for th in theta_vecs:
        if n_per_step == 1:
            x = _argmax_one_point_variance(model, xi0_for_weights, th, bounds, reg=reg, seed=seed, maxiter=da_maxiter, exclude_support=xi0_for_weights.points, exclude_tol=float(exclude_tol))
            X = np.round(x, rounding_digits).reshape(1, d)
        else:
            Xraw = _argmax_two_point_set(
                model, xi0_for_weights, th, bounds,
                alpha_mode=alpha_mode, alpha=alpha, reg=reg, seed=seed, maxiter=da_maxiter,
                exclude_support=xi0_for_weights.points, exclude_tol=float(exclude_tol)
            )
            X = _aug_canonicalize_set(np.round(Xraw, rounding_digits).reshape(2, d))
        delta.append(X)

    # unique Δ (exact after rounding)
    uniq: Dict[Tuple[Tuple[float, ...], ...], PointSet] = {}
    for X in delta:
        key = tuple(tuple(row.tolist()) for row in X)
        uniq[key] = X
    Delta = list(uniq.values())

    # Base efficiencies
    base_effs = [
        _d_efficiency_formal(model, xi0_for_weights, xi_opt[i], theta_vecs[i], reg=reg)
        for i in range(len(grid))
    ]

    # Step 3: choose X1* in Δ maximizing maximum improvement over grid
    best_X1 = None
    best_score = -np.inf
    for X in Delta:
        xi1 = _augment_design(xi0_for_weights, [X], alpha_mode=alpha_mode, alpha=alpha)
        effs1 = [
            _d_efficiency_formal(model, xi1, xi_opt[i], theta_vecs[i], reg=reg)
            for i in range(len(grid))
        ]
        improvements = [effs1[i] - base_effs[i] for i in range(len(grid))]
        score = float(np.max(improvements))  # “maximum difference in the grid” :contentReference[oaicite:13]{index=13}
        if score > best_score:
            best_score = score
            best_X1 = X

    assert best_X1 is not None
    X1_star = np.asarray(best_X1, dtype=float).reshape(n_per_step, d)

    # Step 5: choose X2* in Δ maximizing min efficiency over grid for xi(X2, X1*)
    best_X2 = None
    best_min_eff = -np.inf
    for X2 in Delta:
        xi2 = _augment_design(xi0_for_weights, [X1_star, X2], alpha_mode=alpha_mode, alpha=alpha)
        effs2 = [
            _d_efficiency_formal(model, xi2, xi_opt[i], theta_vecs[i], reg=reg)
            for i in range(len(grid))
        ]
        score = float(np.min(effs2))
        if score > best_min_eff:
            best_min_eff = score
            best_X2 = X2

    assert best_X2 is not None
    X2_star = np.asarray(best_X2, dtype=float).reshape(n_per_step, d)

    xi_augm = _augment_design(xi0_for_weights, [X1_star, X2_star], alpha_mode=alpha_mode, alpha=alpha)

    meta = {
        "criterion": "D",
        "alpha_mode": alpha_mode,
        "alpha": float(alpha) if alpha_mode == "fixed" else None,
        "n_per_step": int(n_per_step),
        "n_added_total": int(2 * n_per_step),
        "uncertain_params": [str(s) for s in uncertain_params],
        "n_scenarios": len(grid),
        "delta_size": len(Delta),
        "rounding_digits": int(rounding_digits),
        "wynn_base": wynn_base,
        "wynn_ref": wynn_ref,
    }

    return RobustAugmentResult(
        design_base=xi0_for_weights,
        design_augm=xi_augm,
        x1_star=X1_star,
        x2_star=X2_star,
        delta=Delta,
        meta=meta,
    )
